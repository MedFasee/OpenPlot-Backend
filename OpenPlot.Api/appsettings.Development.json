{
    "Auth": {
        "UseMock": true,
        "UserStore": { "UsersPath": "auth/users.json" }
    },
    "Session": {
        "CookieName": "openplot_session_dev",
        "IdleTimeoutMinutes": 120,
        "UseMock": true
    },
    "Cors": {
